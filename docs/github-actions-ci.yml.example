---
name: CI

"on":
  push:
  pull_request:

permissions:
  contents: read

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'
          cache: pip

      - name: Install validation dependencies
        run: pip install --requirement requirements-dev.txt

      - name: Install pinned Ansible collections
        run: ansible-galaxy collection install --requirements-file requirements.yml

      - name: Validate YAML
        run: yamllint .

      - name: Lint the Ansible role
        run: ansible-lint site.yml

      - name: Run Ansible syntax check
        run: ansible-playbook --syntax-check site.yml

      - name: Check shell syntax
        run: bash -n scripts/install-ludus-role.sh

      - name: Test the release downloader
        run: python -m unittest discover -s tests -v
